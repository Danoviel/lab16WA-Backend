# Base de datos (Railway provee esta URL automáticamente)
DATABASE_URL="postgresql://usuario:password@host:5432/basedatos?schema=public"

# JWT - genera un secreto largo y aleatorio para producción
JWT_SECRET="tu-secreto-super-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=4000
NODE_ENV=development

# CORS - URL del frontend en Vercel
CORS_ORIGIN="https://tu-frontend.vercel.app"
